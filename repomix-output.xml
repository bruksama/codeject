}

button,
[role='button'],
a,
input,
textarea,
select,
summary {
  touch-action: manipulation;
}

button:focus-visible,
[role='button']:focus-visible,
a:focus-visible,
input:focus-visible,
textarea:focus-visible,
select:focus-visible,
summary:focus-visible,
.interactive-focus-ring:focus-visible {
  outline: 2px solid var(--focus-ring);
  outline-offset: 2px;
  box-shadow: 0 0 0 4px var(--focus-ring-shadow);
}

.mobile-touch-target {
  min-width: 44px;
  min-height: 44px;
}

.skip-link {
  position: fixed;
  left: 16px;
  top: calc(12px + env(safe-area-inset-top, 0px));
  z-index: 100;
  padding: 0.75rem 1rem;
  border-radius: 999px;
  border: 1px solid color-mix(in srgb, var(--accent-primary) 26%, transparent);
  background: rgba(15, 15, 26, 0.96);
  color: var(--text-primary);
  transform: translateY(-160%);
  transition: transform 0.2s ease;
}

.skip-link:focus-visible {
  transform: translateY(0);
}

.content-auto-card {
  content-visibility: auto;
  contain-intrinsic-size: 0 152px;
}

.content-auto-message {
  content-visibility: auto;
  contain-intrinsic-size: 0 140px;
}

.field-support-text {
  min-height: 1.25rem;
}

/* Scrollbar */
::-webkit-scrollbar {
  width: 0px;
  height: 0px;
}

/* Glass card */
.glass-card {
  background: var(--bg-card);
  border: 1px solid var(--border-subtle);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.glass-card-hover:hover {
  background: var(--bg-card-hover);
  border-color: var(--border-medium);
}

.glass-elevated {
  background: var(--bg-elevated);
  border: 1px solid var(--border-medium);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
}

/* Accent gradient */
.accent-gradient {
  background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
}

.accent-gradient-text {
  background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* Glow effects */
.accent-glow {
  box-shadow:
    0 0 20px var(--accent-glow),
    0 0 40px rgba(99, 102, 241, 0.15);
}

.accent-glow-sm {
  box-shadow: 0 0 12px var(--accent-glow);
}

/* Message bubbles */
.bubble-user {
  background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
  border-radius: 18px 18px 4px 18px;
}

.bubble-assistant {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.09);
  border-radius: 18px 18px 18px 4px;
  backdrop-filter: blur(20px);
}

/* Code block */
.code-block {
  font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
  background: rgba(0, 0, 0, 0.5);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 10px;
}

/* Streaming dots */
@keyframes streaming-dot {
  0%,
  60%,
  100% {
    transform: translateY(0);
    opacity: 0.4;
  }
  30% {
    transform: translateY(-4px);
    opacity: 1;
  }
}

.streaming-dot:nth-child(1) {
  animation: streaming-dot 1.2s ease-in-out infinite;
}
.streaming-dot:nth-child(2) {
  animation: streaming-dot 1.2s ease-in-out 0.2s infinite;
}
.streaming-dot:nth-child(3) {
  animation: streaming-dot 1.2s ease-in-out 0.4s infinite;
}

/* FAB pulse */
@keyframes fab-pulse {
  0%,
  100% {
    box-shadow: 0 0 0 0 var(--accent-glow);
  }
  50% {
    box-shadow: 0 0 0 12px rgba(124, 58, 237, 0);
  }
}

.fab-pulse {
  animation: fab-pulse 2.5s ease-in-out infinite;
}

/* Swipe card */
.swipe-card-container {
  position: relative;
  overflow: hidden;
}

/* Connection status pulse */
@keyframes status-pulse {
  0%,
  100% {
    opacity: 1;
  }
  50% {
    opacity: 0.4;
  }
}

.status-pulse {
  animation: status-pulse 2s ease-in-out infinite;
}

/* Bottom tab bar */
.bottom-tab-bar {
  padding-bottom: calc(8px + env(safe-area-inset-bottom, 0px));
}

/* Safe area top */
.safe-top {
  padding-top: env(safe-area-inset-top, 44px);
}

/* Textarea auto-grow */
.auto-grow-textarea {
  resize: none;
  overflow-y: auto;
  min-height: 40px;
  max-height: 144px;
  line-height: 1.5;
}

/* Settings list */
.settings-group {
  border-radius: 14px;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.settings-row {
  transition: background 0.15s ease;
}

.settings-row:active {
  background: rgba(255, 255, 255, 0.08);
}

/* Toggle switch */
.toggle-track {
  transition: background 0.25s ease;
}

/* Slide up animation */
@keyframes slide-up {
  from {
    transform: translateY(20px);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.slide-up {
  animation: slide-up 0.3s ease forwards;
}

/* Fade in */
@keyframes fade-in {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.fade-in {
  animation: fade-in 0.25s ease forwards;
}

/* Scale in */
@keyframes scale-in {
  from {
    transform: scale(0.95);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.scale-in {
  animation: scale-in 0.2s ease forwards;
}

/* Input focus glow */
.input-focus:focus {
  border-color: color-mix(in srgb, var(--accent-primary) 65%, transparent);
  box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-primary) 16%, transparent);
  outline: none;
}

/* Skeleton shimmer */
@keyframes shimmer {
  0% {
    background-position: -200% 0;
  }
  100% {
    background-position: 200% 0;
  }
}

.skeleton {
  background: linear-gradient(
    90deg,
    rgba(255, 255, 255, 0.04) 25%,
    rgba(255, 255, 255, 0.08) 50%,
    rgba(255, 255, 255, 0.04) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 1.8s ease-in-out infinite;
}

/* Swipe delete reveal */
.delete-reveal {
  background: linear-gradient(135deg, #dc2626, #ef4444);
  border-radius: 14px;
}

/* Emoji grid */
.emoji-option {
  transition:
    transform 0.1s ease,
    background 0.15s ease;
}

.emoji-option:active {
  transform: scale(0.9);
}

/* Markdown styles inside chat */
.markdown-content p {
  margin-bottom: 8px;
  line-height: 1.6;
}
.markdown-content p:last-child {
  margin-bottom: 0;
}
.markdown-content strong {
  color: #f1f0ff;
  font-weight: 600;
}
.markdown-content em {
  color: rgba(241, 240, 255, 0.8);
  font-style: italic;
}
.markdown-content ul,
.markdown-content ol {
  margin: 8px 0;
  padding-left: 20px;
}
.markdown-content li {
  margin-bottom: 4px;
  line-height: 1.5;
}
.markdown-content h1,
.markdown-content h2,
.markdown-content h3 {
  font-weight: 600;
  margin: 12px 0 6px;
  background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.markdown-content code {
  font-family: 'JetBrains Mono', monospace;
  background: rgba(0, 0, 0, 0.4);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 4px;
  padding: 1px 5px;
  font-size: 0.85em;
  color: var(--accent-primary);
}
.markdown-content blockquote {
  border-left: 3px solid var(--accent-primary);
  padding-left: 12px;
  margin: 8px 0;
  color: rgba(241, 240, 255, 0.6);
  font-style: italic;
}

/* Accent color dots in picker */
.color-dot {
  transition:
    transform 0.15s ease,
    box-shadow 0.15s ease;
}
.color-dot:active {
  transform: scale(0.85);
}
.color-dot.selected {
  transform: scale(1.15);
  box-shadow:
    0 0 0 2px rgba(255, 255, 255, 0.3),
    0 0 12px currentColor;
}

.accent-chip {
  background: color-mix(in srgb, var(--accent-primary) 14%, transparent);
  border-color: color-mix(in srgb, var(--accent-primary) 24%, transparent);
  color: color-mix(in srgb, var(--accent-primary) 78%, white);
}

.accent-dot {
  background: var(--accent-primary);
}

.accent-text {
  color: var(--accent-primary);
}

@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    scroll-behavior: auto !important;
    transition-duration: 0.01ms !important;
  }
}
