{
  "name": "@codeject/server",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "node --import tsx --test src/**/*.test.ts",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@codeject/shared": "1.1.0",
    "cors": "2.8.6",
    "dotenv": "17.3.1",
    "express": "5.2.1",
    "node-pty": "1.1.0",
    "uuid": "13.0.0",
    "ws": "8.19.0"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "25.5.0",
    "@types/ws": "8.18.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
