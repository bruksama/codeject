{
  "name": "codeject",
  "version": "1.1.0",
  "private": true,
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "safe-stop": "bash ./scripts/safe-stop-runtime.sh",
    "build": "turbo run build",
    "start": "npm run start -w @codeject/server",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "2.8.17"
  },
  "dependencies": {
    "@playwright/test": "1.58.2"
  }
}
